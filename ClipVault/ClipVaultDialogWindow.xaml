<Window x:Class="ClipVault.ClipVaultDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipVault"
        SizeToContent="WidthAndHeight"
        MinWidth="380"
        MaxWidth="760"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#0B1118"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B1118"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#101925"/>
        <SolidColorBrush x:Key="CardBrush" Color="#121C28"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#223040"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#162437"/>
        <SolidColorBrush x:Key="AccentSoftHoverBrush" Color="#1B3047"/>
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#6AB2FF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F3F7FB"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#95A7BC"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#B88B2E"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#A24755"/>
        <SolidColorBrush x:Key="InfoBrush" Color="#355B84"/>

        <RadialGradientBrush x:Key="TopGlowBrush"
                             Center="0.18,0.02"
                             GradientOrigin="0.18,0.02"
                             RadiusX="0.66"
                             RadiusY="0.66">
            <GradientStop Color="#16365B" Offset="0"/>
            <GradientStop Color="#0016365B" Offset="1"/>
        </RadialGradientBrush>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="#162131"/>
            <Setter Property="BorderBrush" Value="#243548"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1C2D43"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#35506E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#223854"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="#315A87"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSoftHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Canvas ClipToBounds="False"
            IsHitTestVisible="False">
            <Ellipse Width="720"
                 Height="720"
                 Fill="{StaticResource TopGlowBrush}"
                 Canvas.Left="-180"
                 Canvas.Top="-260"/>
        </Canvas>

        <Border Margin="16"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource CardBorderBrush}"
            BorderThickness="1"
            CornerRadius="22"
            Padding="18"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="IconBadge"
                        Width="42"
                        Height="42"
                        CornerRadius="21"
                        Background="{StaticResource InfoBrush}"
                        VerticalAlignment="Top">
                        <TextBlock x:Name="IconGlyphTextBlock"
                               Text="i"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="TitleTextBlock"
                           Grid.Column="2"
                           FontSize="21"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           VerticalAlignment="Center"/>
                </Grid>

                <Border Grid.Row="2"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="16">
                    <TextBlock x:Name="MessageTextBlock"
                           MaxWidth="560"
                           TextWrapping="Wrap"
                           FontSize="14"
                           LineHeight="22"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                </Border>

                <StackPanel Grid.Row="4"
                        x:Name="ButtonsPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>