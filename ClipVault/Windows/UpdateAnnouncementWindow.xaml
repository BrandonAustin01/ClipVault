<Window x:Class="ClipVault.UpdateAnnouncementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What's New in ClipVault"
        Width="800"
        Height="320"
        MinWidth="800"
        MinHeight="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0B1118">

    <Window.Resources>
        <!-- Core palette -->
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B1118"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#101925"/>
        <SolidColorBrush x:Key="CardBrush" Color="#121C28"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#152233"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#223040"/>
        <SolidColorBrush x:Key="CardBorderHoverBrush" Color="#33506F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4EA1FF"/>
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#6AB2FF"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#162437"/>
        <SolidColorBrush x:Key="AccentSoftHoverBrush" Color="#1B3047"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F3F7FB"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#95A7BC"/>
        <SolidColorBrush x:Key="TextSoftBrush" Color="#B9C6D5"/>

        <!-- Scroll chrome -->
        <SolidColorBrush x:Key="ScrollTrackBrush" Color="#0F1823"/>
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#2A4159"/>
        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#365674"/>
        <SolidColorBrush x:Key="ScrollThumbPressedBrush" Color="#46719A"/>

        <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="{StaticResource ScrollThumbBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder"
                                Property="Background"
                                Value="{StaticResource ScrollThumbHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder"
                                Property="Background"
                                Value="{StaticResource ScrollThumbPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border Background="{StaticResource ScrollTrackBrush}"
                            CornerRadius="6"
                            Margin="1"/>

                            <Track x:Name="PART_Track"
                           IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollRepeatButtonStyle}"
                                          Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbStyle}"/>
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollRepeatButtonStyle}"
                                          Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="12"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="12"/>
                                <Setter Property="Height" Value="Auto"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Ambient glow -->
        <RadialGradientBrush x:Key="TopGlowBrush"
                             Center="0.18,0.02"
                             GradientOrigin="0.18,0.02"
                             RadiusX="0.66"
                             RadiusY="0.66">
            <GradientStop Color="#16365B" Offset="0"/>
            <GradientStop Color="#0016365B" Offset="1"/>
        </RadialGradientBrush>

        <RadialGradientBrush x:Key="BottomGlowBrush"
                             Center="0.88,1.00"
                             GradientOrigin="0.88,1.00"
                             RadiusX="0.74"
                             RadiusY="0.74">
            <GradientStop Color="#11263F" Offset="0"/>
            <GradientStop Color="#0011263F" Offset="1"/>
        </RadialGradientBrush>

        <!-- Shared surfaces -->
        <Style x:Key="SurfaceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="0"
                                      Color="#0A1320"
                                      Opacity="0.32"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource CardBorderHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Shared buttons -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="#162131"/>
            <Setter Property="BorderBrush" Value="#243548"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1C2D43"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#35506E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#223854"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="#315A87"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSoftHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#25425F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Ellipse Width="760"
                 Height="760"
                 Fill="{StaticResource TopGlowBrush}"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-180,-250,0,0"
                 IsHitTestVisible="False"/>

        <Ellipse Width="860"
                 Height="860"
                 Fill="{StaticResource BottomGlowBrush}"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-220,-310"
                 IsHitTestVisible="False"/>

        <Grid Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="ClipVault was updated"
                               FontSize="29"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="VersionTextBlock"
                               Margin="0,7,0,0"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#132338"
                        BorderBrush="#355B84"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="Update installed"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <!-- Summary -->
            <Border Grid.Row="2"
                    Style="{StaticResource SurfaceCardStyle}"
                    Background="{StaticResource PanelBrush}">
                <TextBlock x:Name="SummaryTextBlock"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14"
                           LineHeight="22"/>
            </Border>

            <!-- Changelog -->
            <Border x:Name="ChangelogBorder"
                    Grid.Row="4"
                    Style="{StaticResource SurfaceCardStyle}"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Changelog"
                               FontSize="16"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>

                    <TextBox x:Name="ChangelogTextBox"
                             Grid.Row="2"
                             Padding="0"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{StaticResource TextSoftBrush}"
                             FontSize="13"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled"/>
                </Grid>
            </Border>

            <!-- Footer buttons -->
            <StackPanel Grid.Row="6"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="ToggleChangelogButton"
                        Content="View Changelog"
                        Width="150"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="ToggleChangelogButton_Click"/>

                <Button Content="Close"
                        Width="110"
                        Margin="0"
                        Style="{StaticResource ActionButtonStyle}"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>