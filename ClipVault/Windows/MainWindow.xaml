<Window x:Class="ClipVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ClipVault"
        Icon="pack://application:,,,/Resources/App.ico"
        Width="1360"
        Height="820"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"       
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B1118"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#0F1722"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#101925"/>
        <SolidColorBrush x:Key="CardBrush" Color="#121C28"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#152233"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#223040"/>
        <SolidColorBrush x:Key="CardBorderHoverBrush" Color="#33506F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4EA1FF"/>
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#6AB2FF"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#162437"/>
        <SolidColorBrush x:Key="AccentSoftHoverBrush" Color="#1B3047"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F3F7FB"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#95A7BC"/>
        <SolidColorBrush x:Key="TextSoftBrush" Color="#B9C6D5"/>
        <SolidColorBrush x:Key="SidebarSelectedBrush" Color="#162437"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#6F2630"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#87303A"/>
        <SolidColorBrush x:Key="DangerBorderBrush" Color="#A24755"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0E1620"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#263547"/>
        <SolidColorBrush x:Key="InputBorderHoverBrush" Color="#37506A"/>

        <SolidColorBrush x:Key="CardGlowBrush" Color="#1A2C43"/>
        <SolidColorBrush x:Key="SurfaceTopStrokeBrush" Color="#314A64"/>
        <SolidColorBrush x:Key="SurfaceBottomStrokeBrush" Color="#172331"/>
        <SolidColorBrush x:Key="PillBackgroundBrush" Color="#162334"/>
        <SolidColorBrush x:Key="PillBorderBrush" Color="#29435D"/>
        <SolidColorBrush x:Key="PinnedCardBrush" Color="#142334"/>
        <SolidColorBrush x:Key="PinnedBorderBrush" Color="#4A86C7"/>

        <SolidColorBrush x:Key="SidebarHoverBrush" Color="#142131"/>
        <SolidColorBrush x:Key="SidebarHoverBorderBrush" Color="#24384C"/>
        <SolidColorBrush x:Key="SidebarPressedBrush" Color="#1A2D42"/>
        <SolidColorBrush x:Key="SidebarPressedBorderBrush" Color="#36506D"/>

        <SolidColorBrush x:Key="ActionButtonBackgroundBrush" Color="#162131"/>
        <SolidColorBrush x:Key="ActionButtonBorderBrush" Color="#243548"/>
        <SolidColorBrush x:Key="ActionButtonHoverBrush" Color="#1C2D43"/>
        <SolidColorBrush x:Key="ActionButtonHoverBorderBrush" Color="#35506E"/>
        <SolidColorBrush x:Key="ActionButtonPressedBrush" Color="#223854"/>
        <SolidColorBrush x:Key="PrimaryButtonBorderBrush" Color="#315A87"/>
        <SolidColorBrush x:Key="PrimaryButtonPressedBrush" Color="#25425F"/>
        <SolidColorBrush x:Key="DangerHoverBorderBrush" Color="#BF5A69"/>
        <SolidColorBrush x:Key="DangerPressedBrush" Color="#6C2630"/>

        <SolidColorBrush x:Key="SidebarOuterBorderBrush" Color="#182433"/>
        <SolidColorBrush x:Key="SidebarHeaderBorderBrush" Color="#263B52"/>
        <SolidColorBrush x:Key="StorageBadgeBackgroundBrush" Color="#132338"/>
        <SolidColorBrush x:Key="StorageBadgeBorderBrush" Color="#355B84"/>
        <SolidColorBrush x:Key="StorageBadgeShadowBrush" Color="#0B1623"/>
        <SolidColorBrush x:Key="ComboBoxPopupBrush" Color="#101925"/>
        <SolidColorBrush x:Key="ComboBoxPopupBorderBrush" Color="#223040"/>

        <LinearGradientBrush x:Key="SidebarHeaderGlowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A2B40" Offset="0"/>
            <GradientStop Color="#0F1722" Offset="1"/>
        </LinearGradientBrush>

        <SolidColorBrush x:Key="ScrollTrackBrush" Color="#0F1823"/>
        <SolidColorBrush x:Key="ScrollThumbBrush" Color="#2A4159"/>
        <SolidColorBrush x:Key="ScrollThumbHoverBrush" Color="#365674"/>
        <SolidColorBrush x:Key="ScrollThumbPressedBrush" Color="#46719A"/>

        <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="{StaticResource ScrollThumbBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="ThumbBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Margin="1"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ThumbBorder"
                                        Property="Background"
                                        Value="{StaticResource ScrollThumbHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="ThumbBorder"
                                        Property="Background"
                                        Value="{StaticResource ScrollThumbPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ScrollRepeatButtonStyle" TargetType="RepeatButton">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Border Background="{StaticResource ScrollTrackBrush}"
                                    CornerRadius="6"
                                    Margin="1"/>

                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollRepeatButtonStyle}"
                                                  Command="ScrollBar.PageUpCommand"/>
                                </Track.DecreaseRepeatButton>

                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollThumbStyle}"/>
                                </Track.Thumb>

                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource ScrollRepeatButtonStyle}"
                                                  Command="ScrollBar.PageDownCommand"/>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Width" Value="Auto"/>
                                <Setter Property="Height" Value="12"/>
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="12"/>
                                <Setter Property="Height" Value="Auto"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <RadialGradientBrush x:Key="TopGlowBrush"
                             Center="0.18,0.0"
                             GradientOrigin="0.18,0.0"
                             RadiusX="0.62"
                             RadiusY="0.62">
            <GradientStop Color="#16365B" Offset="0"/>
            <GradientStop Color="#0016365B" Offset="1"/>
        </RadialGradientBrush>

        <RadialGradientBrush x:Key="BottomGlowBrush"
                             Center="0.88,1.08"
                             GradientOrigin="0.88,1.08"
                             RadiusX="0.72"
                             RadiusY="0.72">
            <GradientStop Color="#11263F" Offset="0"/>
            <GradientStop Color="#0011263F" Offset="1"/>
        </RadialGradientBrush>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SidebarHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SidebarHoverBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource SidebarPressedBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource SidebarPressedBorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentSoftBrush}"/>
        </Style>

        <Style x:Key="SettingCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Border x:Name="Box"
                                    Width="16"
                                    Height="16"
                                    CornerRadius="4"
                                    Background="{StaticResource InputBackgroundBrush}"
                                    BorderBrush="{StaticResource InputBorderBrush}"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"/>

                            <Path x:Name="CheckMark"
                                  Grid.Column="0"
                                  Width="9"
                                  Height="7"
                                  Stroke="{StaticResource TextPrimaryBrush}"
                                  StrokeThickness="2"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Data="M 1 4 L 3.5 6.5 L 8 1.5"
                                  Visibility="Collapsed"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>

                            <ContentPresenter Grid.Column="2"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{StaticResource AccentStrongBrush}"/>
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Margin="6,4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource AccentSoftBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SidebarSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThemeComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="220"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0,40,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ThemeComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="12"/>

                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              RecognizesAccessKey="True"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                            <Path x:Name="Arrow"
                                  Width="10"
                                  Height="6"
                                  HorizontalAlignment="Right"
                                  Margin="0,0,14,0"
                                  VerticalAlignment="Center"
                                  Fill="{StaticResource TextMutedBrush}"
                                  Data="M 0 0 L 5 6 L 10 0 Z"/>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,8,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{StaticResource ComboBoxPopupBrush}"
                                        BorderBrush="{StaticResource ComboBoxPopupBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <ScrollViewer Margin="6"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource InputBorderHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{StaticResource AccentStrongBrush}"/>
                                <Setter TargetName="Arrow" Property="Fill" Value="{StaticResource AccentStrongBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{StaticResource ActionButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ActionButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource ActionButtonHoverBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource ActionButtonHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource ActionButtonPressedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryButtonBorderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSoftHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryButtonPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBorderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource DangerHoverBorderBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsActionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="SettingsPrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="SettingsDangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DangerButtonStyle}">
            <Setter Property="Height" Value="42"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <Style x:Key="HistoryItemButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="HistoryItemPrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="HistoryItemDangerButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DangerButtonStyle}">
            <Setter Property="Width" Value="96"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="12,0"/>
        </Style>

        <Style x:Key="SurfaceCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10"
                                      ShadowDepth="0"
                                      Color="#0A1320"
                                      Opacity="0.22"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource CardBorderHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingsCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
            <Setter Property="Effect" Value="{x:Null}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="ItemCardStyle" TargetType="Border" BasedOn="{StaticResource SurfaceCardStyle}">
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="Padding" Value="18"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter Property="Background" Value="{StaticResource PinnedCardBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource PinnedBorderBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Ellipse Width="860"
                 Height="860"
                 Fill="{StaticResource TopGlowBrush}"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="-180,-260,0,0"
                 IsHitTestVisible="False"
                 Panel.ZIndex="0"/>

        <Ellipse Width="940"
                 Height="940"
                 Fill="{StaticResource BottomGlowBrush}"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Bottom"
                 Margin="0,0,-260,-320"
                 IsHitTestVisible="False"
                 Panel.ZIndex="0"/>

        <Grid Panel.ZIndex="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="238"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource SidebarOuterBorderBrush}"
                    BorderThickness="0,0,1,0">
                <Grid Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="20"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0"
                            Background="{StaticResource SidebarHeaderGlowBrush}"
                            BorderBrush="{StaticResource SidebarHeaderBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="20"
                            Padding="18">
                        <StackPanel>
                            <TextBlock Text="ClipVault"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock Text="{Binding DisplayVersion, StringFormat=CVX Build {0}}"
                                       Margin="0,8,0,0"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Opacity="0.95"/>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="2">
                        <Button x:Name="BtnHistory"
                                Content="History"
                                Tag="History"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="SectionButton_Click"/>

                        <Button x:Name="BtnPinned"
                                Content="Pinned"
                                Tag="Pinned"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="SectionButton_Click"/>

                        <Button x:Name="BtnSnippets"
                                Content="Snippets"
                                Tag="Snippets"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="SectionButton_Click"/>

                        <Button x:Name="BtnSettings"
                                Content="Settings"
                                Tag="Settings"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="SectionButton_Click"/>
                    </StackPanel>

                    <Border Grid.Row="3"
                            Background="Transparent"
                            Padding="2,10,2,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Ellipse Width="8"
                                     Height="8"
                                     VerticalAlignment="Top"
                                     Margin="0,4,0,0"
                                     Fill="{StaticResource AccentBrush}"
                                     Opacity="0.9"/>

                            <TextBlock Grid.Column="2"
                                       Text="{Binding StatusMessage}"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"
                                       LineHeight="18"
                                       Opacity="0.95"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Column="1" Margin="22">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="{Binding CurrentSectionTitle}"
                                   FontSize="31"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding CurrentSectionSubtitle}"
                                   Margin="0,6,0,0"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource StorageBadgeBackgroundBrush}"
                            BorderBrush="{StaticResource StorageBadgeBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="14,9"
                            VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="14"
                                              ShadowDepth="0"
                                              Color="{Binding Color, Source={StaticResource StorageBadgeShadowBrush}}"
                                              Opacity="0.28"/>
                        </Border.Effect>
                        <TextBlock Text="Local SQLite storage"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>

                <Border x:Name="SearchActionPanel"
                        Grid.Row="1"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="16"
                        Margin="0,0,0,18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="SearchTextBox"
                                 Grid.Column="0"
                                 Style="{StaticResource TextInputStyle}"
                                 ToolTip="Search titles, categories, and content"
                                 TextChanged="SearchTextBox_TextChanged"/>

                        <Button Grid.Column="1"
                                Content="Clear Search"
                                Margin="12,0,8,0"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="ClearSearchButton_Click"/>

                        <Button Grid.Column="2"
                                Content="New Snippet"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="NewSnippetButton_Click"/>
                    </Grid>
                </Border>

                <UniformGrid x:Name="StatsPanel"
                             Grid.Row="2"
                             Columns="3"
                             Margin="0,0,0,18">
                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Clipboard Items"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding TotalCount}"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Pinned"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding PinnedCount}"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SurfaceCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Snippets"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="12"/>
                            <TextBlock Text="{Binding SnippetCount}"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="32"
                                       FontWeight="Bold"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Grid Grid.Row="3">
                    <Border x:Name="ClipboardContentPanel"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22"
                            Padding="18">
                        <Grid>
                            <TextBlock x:Name="NoItemsText"
                                       Text="Nothing to show here yet.&#10;Copy something, pin favorites, or create a snippet."
                                       Visibility="Collapsed"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       TextAlignment="Center"
                                       FontSize="18"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       LineHeight="28"/>

                            <ScrollViewer x:Name="ClipboardScroller"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding FilteredItems}" Margin="0,0,8,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ItemCardStyle}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Grid Grid.Row="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontSize="16"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       VerticalAlignment="Center"/>

                                                            <Border Background="{StaticResource PillBackgroundBrush}"
                                                                    BorderBrush="{StaticResource PillBorderBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="11"
                                                                    Padding="10,4"
                                                                    Margin="12,0,0,0"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding PinStateLabel}"
                                                                           Foreground="{StaticResource AccentStrongBrush}"
                                                                           FontSize="11"
                                                                           FontWeight="SemiBold"/>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Grid.Row="1"
                                                               Margin="0,16,0,16"
                                                               Text="{Binding DisplayText}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource TextSoftBrush}"
                                                               FontSize="14"
                                                               LineHeight="24"/>

                                                    <Grid Grid.Row="2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <StackPanel Orientation="Horizontal"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DateLabel}"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       FontSize="12"/>
                                                            <TextBlock Text=" • "
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       FontSize="12"/>
                                                            <TextBlock Text="{Binding TimeLabel}"
                                                                       Foreground="{StaticResource TextMutedBrush}"
                                                                       FontSize="12"/>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center"
                                                                    Margin="16,0,0,0">
                                                            <Button Content="Copy"
                                                                    Tag="{Binding Id}"
                                                                    Style="{StaticResource HistoryItemPrimaryButtonStyle}"
                                                                    Click="CopyItemButton_Click"/>

                                                            <Button Content="{Binding PinButtonLabel}"
                                                                    Tag="{Binding Id}"
                                                                    Style="{StaticResource HistoryItemButtonStyle}"
                                                                    Click="TogglePinButton_Click"/>

                                                            <Button Content="Edit"
                                                                    Tag="{Binding Id}"
                                                                    Click="EditSnippetButton_Click">
                                                                <Button.Style>
                                                                    <Style TargetType="Button" BasedOn="{StaticResource HistoryItemButtonStyle}">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsSnippet}" Value="True">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>

                                                            <Button Content="Delete"
                                                                    Tag="{Binding Id}"
                                                                    Style="{StaticResource HistoryItemDangerButtonStyle}"
                                                                    Click="DeleteItemButton_Click"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <Border x:Name="SettingsContentPanel"
                            Visibility="Collapsed"
                            Background="{StaticResource PanelBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="22"
                            Padding="20">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <Border Style="{StaticResource SettingsCardStyle}"
                                        Padding="22">
                                    <StackPanel>
                                        <TextBlock Text="General"
                                                   FontSize="20"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <TextBlock Text="Core ClipVault behavior and local app preferences."
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap"/>

                                        <CheckBox x:Name="ChkLaunchOnStartup"
                                                  Content="Launch ClipVault on startup"
                                                  Margin="0,22,0,0"
                                                  Style="{StaticResource SettingCheckBoxStyle}"/>

                                        <CheckBox x:Name="ChkClipboardMonitoring"
                                                  Content="Watch clipboard changes automatically"
                                                  Margin="0,10,0,0"
                                                  Style="{StaticResource SettingCheckBoxStyle}"/>

                                        <CheckBox x:Name="ChkMinimizeToTray"
                                                  Content="Minimize to system tray"
                                                  Margin="0,10,0,0"
                                                  Style="{StaticResource SettingCheckBoxStyle}"/>

                                        <CheckBox x:Name="ChkCloseToTray"
                                                  Content="Close to system tray instead of exiting"
                                                  Margin="0,10,0,0"
                                                  Style="{StaticResource SettingCheckBoxStyle}"/>

                                        <TextBlock Text="Theme"
                                                   Margin="0,22,0,8"
                                                   Foreground="{StaticResource TextMutedBrush}"/>

                                        <ComboBox x:Name="ThemeComboBox"
                                                  Width="220"
                                                  HorizontalAlignment="Left"
                                                  Style="{StaticResource ThemeComboBoxStyle}"
                                                  SelectedValuePath="Tag"
                                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Midnight" Tag="Midnight"/>
                                            <ComboBoxItem Content="Graphite" Tag="Graphite"/>
                                            <ComboBoxItem Content="Aurora" Tag="Aurora"/>
                                        </ComboBox>

                                        <TextBlock Text="Max history items"
                                                   Margin="0,22,0,8"
                                                   Foreground="{StaticResource TextMutedBrush}"/>

                                        <TextBox x:Name="MaxHistoryItemsTextBox"
                                                 Width="220"
                                                 HorizontalAlignment="Left"
                                                 Style="{StaticResource TextInputStyle}"/>

                                        <Grid Margin="0,22,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Settings are stored locally in SQLite."
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       TextWrapping="Wrap"/>

                                            <Button Grid.Column="1"
                                                    Content="Save Settings"
                                                    Width="150"
                                                    Margin="16,0,0,0"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Click="SaveSettingsButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,14,0,0"
                                        Style="{StaticResource SettingsCardStyle}"
                                        Padding="22">
                                    <StackPanel>
                                        <TextBlock Text="Data &amp; Backup"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <TextBlock Text="Protect your local clipboard history, snippets, and app settings."
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap"/>

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Content="Export Backup"
                                                    Style="{StaticResource SettingsActionButtonStyle}"
                                                    Click="ExportBackupButton_Click"/>

                                            <Button Grid.Column="2"
                                                    Content="Import Backup"
                                                    Style="{StaticResource SettingsActionButtonStyle}"
                                                    Click="ImportBackupButton_Click"/>

                                            <Button Grid.Column="4"
                                                    Content="Open Data Folder"
                                                    Style="{StaticResource SettingsActionButtonStyle}"
                                                    Click="OpenDataFolderButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,14,0,0"
                                        Style="{StaticResource SettingsCardStyle}"
                                        Padding="22">
                                    <StackPanel>
                                        <TextBlock Text="Updates"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <TextBlock Text="Stay current and review what changed."
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap"/>

                                        <TextBlock Text="ClipVault checks the official release feed built into this app."
                                                   Margin="0,14,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap"/>

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Content="Check for Updates"
                                                    Style="{StaticResource SettingsPrimaryButtonStyle}"
                                                    Click="CheckForUpdatesButton_Click"/>

                                            <Button Grid.Column="2"
                                                    Content="View Changelog"
                                                    Style="{StaticResource SettingsActionButtonStyle}"
                                                    Click="ViewCurrentChangelogButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,14,0,0"
                                        Style="{StaticResource SettingsCardStyle}"
                                        Padding="22">
                                    <StackPanel>
                                        <TextBlock Text="Maintenance"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <TextBlock Text="Logs, cleanup tools, and local diagnostics."
                                                   Margin="0,6,0,0"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   TextWrapping="Wrap"/>

                                        <Grid Margin="0,18,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="10"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button Grid.Column="0"
                                                    Content="View Current Log"
                                                    Style="{StaticResource SettingsActionButtonStyle}"
                                                    Click="OpenLogViewerButton_Click"/>

                                            <Button Grid.Column="2"
                                                    Content="Open Logs Folder"
                                                    Style="{StaticResource SettingsActionButtonStyle}"
                                                    Click="OpenLogsFolderButton_Click"/>

                                            <Button Grid.Column="4"
                                                    Content="Clear Non-Pinned History"
                                                    Style="{StaticResource SettingsDangerButtonStyle}"
                                                    Click="ClearHistoryButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,14,0,0"
                                        Style="{StaticResource SettingsCardStyle}"
                                        Padding="22">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="24"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Database"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12"/>
                                            <TextBlock Text="{Binding DatabasePath}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Current log"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="12"/>
                                            <TextBlock Text="{Binding CurrentLogPath}"
                                                       Margin="0,8,0,0"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>