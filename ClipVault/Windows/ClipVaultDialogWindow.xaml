<Window x:Class="ClipVault.ClipVaultDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipVault"
        SizeToContent="WidthAndHeight"
        MinWidth="380"
        MaxWidth="760"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ActionButtonBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ActionButtonBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="MinWidth" Value="108"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ActionButtonHoverBrush}"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource ActionButtonHoverBorderBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource ActionButtonPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryButtonBorderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentSoftHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentStrongBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PrimaryButtonPressedBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Canvas ClipToBounds="False"
                IsHitTestVisible="False">
            <Ellipse Width="720"
                     Height="720"
                     Fill="{DynamicResource TopGlowBrush}"
                     Canvas.Left="-180"
                     Canvas.Top="-260"/>
        </Canvas>

        <Border Margin="16"
                Background="{DynamicResource PanelBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="22"
                Padding="18"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Top">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="IconBadge"
                            Width="42"
                            Height="42"
                            CornerRadius="21"
                            Background="{DynamicResource AccentBrush}"
                            VerticalAlignment="Top">
                        <TextBlock x:Name="IconGlyphTextBlock"
                                   Text="i"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="TitleTextBlock"
                               Grid.Column="2"
                               FontSize="21"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </Grid>

                <Border Grid.Row="2"
                        Background="{DynamicResource CardBrush}"
                        BorderBrush="{DynamicResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="16"
                        Padding="16">
                    <TextBlock x:Name="MessageTextBlock"
                               MaxWidth="560"
                               TextWrapping="Wrap"
                               FontSize="14"
                               LineHeight="22"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                </Border>

                <StackPanel Grid.Row="4"
                            x:Name="ButtonsPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>
</Window>