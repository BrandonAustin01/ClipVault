<Window x:Class="ClipVault.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="ClipVault"
        Icon="pack://application:,,,/Resources/App.ico"
        Width="1360"
        Height="820"
        MinWidth="1100"
        MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#0B1118">

    <Window.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B1118"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#0F1722"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#101925"/>
        <SolidColorBrush x:Key="CardBrush" Color="#121C28"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#152233"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#223040"/>
        <SolidColorBrush x:Key="CardBorderHoverBrush" Color="#33506F"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#4EA1FF"/>
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#6AB2FF"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#162437"/>
        <SolidColorBrush x:Key="AccentSoftHoverBrush" Color="#1B3047"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F3F7FB"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#95A7BC"/>
        <SolidColorBrush x:Key="TextSoftBrush" Color="#B9C6D5"/>
        <SolidColorBrush x:Key="SidebarSelectedBrush" Color="#162437"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#6F2630"/>
        <SolidColorBrush x:Key="DangerHoverBrush" Color="#87303A"/>
        <SolidColorBrush x:Key="DangerBorderBrush" Color="#A24755"/>
        <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0E1620"/>
        <SolidColorBrush x:Key="InputBorderBrush" Color="#263547"/>
        <SolidColorBrush x:Key="InputBorderHoverBrush" Color="#37506A"/>

        <LinearGradientBrush x:Key="SidebarHeaderGlowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A2B40" Offset="0"/>
            <GradientStop Color="#0F1722" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#142131"/>
                    <Setter Property="BorderBrush" Value="#24384C"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#1A2D42"/>
                    <Setter Property="BorderBrush" Value="#36506D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{StaticResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{StaticResource AccentSoftBrush}"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="#162131"/>
            <Setter Property="BorderBrush" Value="#243548"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1C2D43"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#35506E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#223854"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="#315A87"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSoftHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#25425F"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource DangerBorderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="#BF5A69"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#6C2630"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource CardBorderHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="238"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource SidebarBrush}"
                BorderBrush="#182433"
                BorderThickness="0,0,1,0">
            <Grid Margin="18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource SidebarHeaderGlowBrush}"
                        BorderBrush="#203145"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="ClipVault"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding DisplayVersion, StringFormat=CVX Build {0}}"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="2">
                    <Button x:Name="BtnHistory"
                            Content="History"
                            Tag="History"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="SectionButton_Click"/>

                    <Button x:Name="BtnPinned"
                            Content="Pinned"
                            Tag="Pinned"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="SectionButton_Click"/>

                    <Button x:Name="BtnSnippets"
                            Content="Snippets"
                            Tag="Snippets"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="SectionButton_Click"/>

                    <Button x:Name="BtnSettings"
                            Content="Settings"
                            Tag="Settings"
                            Style="{StaticResource SidebarButtonStyle}"
                            Click="SectionButton_Click"/>
                </StackPanel>

                <Border Grid.Row="3"
                        Background="#121C28"
                        BorderBrush="#223040"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="14">
                    <StackPanel>
                        <TextBlock Text="Status"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding StatusMessage}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="13"
                                   LineHeight="20"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="{Binding CurrentSectionTitle}"
                               FontSize="31"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding CurrentSectionSubtitle}"
                               Margin="0,6,0,0"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource AccentSoftBrush}"
                        BorderBrush="#315A87"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12,8"
                        VerticalAlignment="Center">
                    <TextBlock Text="Local SQLite storage"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontWeight="SemiBold"/>
                </Border>
            </Grid>

            <Border x:Name="SearchActionPanel"
                    Grid.Row="1"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="16"
                    Margin="0,0,0,18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox x:Name="SearchTextBox"
                             Grid.Column="0"
                             Style="{StaticResource TextInputStyle}"
                             ToolTip="Search titles, categories, and content"
                             TextChanged="SearchTextBox_TextChanged"/>

                    <Button Grid.Column="1"
                            Content="Clear Search"
                            Margin="12,0,8,0"
                            Style="{StaticResource ActionButtonStyle}"
                            Click="ClearSearchButton_Click"/>

                    <Button Grid.Column="2"
                            Content="New Snippet"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="NewSnippetButton_Click"/>
                </Grid>
            </Border>

            <UniformGrid x:Name="StatsPanel"
                         Grid.Row="2"
                         Columns="3"
                         Margin="0,0,0,18">
                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Clipboard Items"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding TotalCount}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Pinned"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding PinnedCount}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource StatCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Snippets"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding SnippetCount}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="30"
                                   FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Grid Grid.Row="3">
                <Border x:Name="ClipboardContentPanel"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="22"
                        Padding="18">
                    <Grid>
                        <TextBlock x:Name="NoItemsText"
                                   Text="Nothing to show here yet.&#10;Copy something, pin favorites, or create a snippet."
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   TextAlignment="Center"
                                   FontSize="18"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   LineHeight="28"/>

                        <ScrollViewer x:Name="ClipboardScroller"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,14"
                                                Padding="16"
                                                Background="{StaticResource CardBrush}"
                                                BorderThickness="1"
                                                CornerRadius="18">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
                                                    <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{StaticResource CardBorderHoverBrush}"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                            <Setter Property="Background" Value="#142232"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                                   VerticalAlignment="Center"/>

                                                        <Border Background="#162131"
                                                                BorderBrush="#27405C"
                                                                BorderThickness="1"
                                                                CornerRadius="10"
                                                                Padding="8,4"
                                                                Margin="10,0,0,0">
                                                            <TextBlock Text="{Binding Category}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       FontSize="11"
                                                                       FontWeight="SemiBold"/>
                                                        </Border>
                                                    </StackPanel>

                                                    <Border Grid.Column="1"
                                                            Background="#101A27"
                                                            BorderBrush="#243548"
                                                            BorderThickness="1"
                                                            CornerRadius="10"
                                                            Padding="8,4">
                                                        <TextBlock Text="{Binding PinStateLabel}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>

                                                <TextBlock Grid.Row="1"
                                                           Margin="0,14,0,14"
                                                           Text="{Binding DisplayText}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextSoftBrush}"
                                                           FontSize="14"
                                                           LineHeight="22"/>

                                                <Grid Grid.Row="2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Orientation="Horizontal"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DateLabel}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="12"/>
                                                        <TextBlock Text=" • "
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="12"/>
                                                        <TextBlock Text="{Binding TimeLabel}"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   FontSize="12"/>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <Button Content="Copy"
                                                                Tag="{Binding Id}"
                                                                Style="{StaticResource PrimaryButtonStyle}"
                                                                Click="CopyItemButton_Click"/>

                                                        <Button Content="{Binding PinButtonLabel}"
                                                                Tag="{Binding Id}"
                                                                Style="{StaticResource ActionButtonStyle}"
                                                                Click="TogglePinButton_Click"/>

                                                        <Button Content="Edit"
                                                                Tag="{Binding Id}"
                                                                Click="EditSnippetButton_Click">
                                                            <Button.Style>
                                                                <Style TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSnippet}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Button.Style>
                                                        </Button>

                                                        <Button Content="Delete"
                                                                Tag="{Binding Id}"
                                                                Style="{StaticResource DangerButtonStyle}"
                                                                Margin="0,0,0,0"
                                                                Click="DeleteItemButton_Click"/>
                                                    </StackPanel>
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <Border x:Name="SettingsContentPanel"
        Visibility="Collapsed"
        Background="{StaticResource PanelBrush}"
        BorderBrush="{StaticResource CardBorderBrush}"
        BorderThickness="1"
        CornerRadius="22"
        Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="18"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Top row -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.15*"/>
                                    <ColumnDefinition Width="0.85*"/>
                                </Grid.ColumnDefinitions>

                                <!-- General -->
                                <Border Grid.Column="0"
                        Margin="0,0,10,0"
                        Background="{StaticResource CardBrush}"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="18"
                        Padding="22">
                                    <StackPanel>
                                        <TextBlock Text="General"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <TextBlock Text="Core ClipVault behavior and local app preferences."
                                   Margin="0,6,0,0"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"/>

                                        <CheckBox x:Name="ChkLaunchOnStartup"
                                  Content="Launch ClipVault on startup"
                                  Margin="0,22,0,0"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <CheckBox x:Name="ChkClipboardMonitoring"
                                  Content="Watch clipboard changes automatically"
                                  Margin="0,10,0,0"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <CheckBox x:Name="ChkMinimizeToTray"
                                  Content="Minimize to system tray"
                                  Margin="0,10,0,0"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <CheckBox x:Name="ChkCloseToTray"
                                  Content="Close to system tray instead of exiting"
                                  Margin="0,10,0,0"
                                  Foreground="{StaticResource TextPrimaryBrush}"/>

                                        <TextBlock Text="Max history items"
                                   Margin="0,22,0,8"
                                   Foreground="{StaticResource TextMutedBrush}"/>

                                        <TextBox x:Name="MaxHistoryItemsTextBox"
                                 Width="220"
                                 HorizontalAlignment="Left"
                                 Style="{StaticResource TextInputStyle}"/>

                                        <Border Margin="0,22,0,0"
                                Background="#0F1823"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Updates"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           FontSize="12"/>
                                                <TextBlock Text="ClipVault checks the official release feed built into this app."
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Grid Margin="0,22,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Text="Settings are stored locally in SQLite."
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>

                                            <Button Grid.Column="1"
                                    Content="Save Settings"
                                    Width="150"
                                    Margin="16,0,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="SaveSettingsButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Right column -->
                                <Grid Grid.Column="1" Margin="10,0,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="14"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Data & Backup -->
                                    <Border Grid.Row="0"
                            Background="{StaticResource CardBrush}"
                            BorderBrush="{StaticResource CardBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="18"
                            Padding="22">
                                        <StackPanel>
                                            <TextBlock Text="Data &amp; Backup"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>

                                            <TextBlock Text="Protect your local clipboard history, snippets, and app settings."
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       TextWrapping="Wrap"/>

                                            <WrapPanel Margin="0,18,0,0">
                                                <Button Content="Export Backup"
                                        Width="145"
                                        Margin="0,0,10,10"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="ExportBackupButton_Click"/>

                                                <Button Content="Import Backup"
                                        Width="145"
                                        Margin="0,0,0,10"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="ImportBackupButton_Click"/>

                                                <Button Content="Open Data Folder"
                                        Width="145"
                                        Margin="0,0,10,0"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="OpenDataFolderButton_Click"/>
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <!-- Updates + Maintenance -->
                                    <Grid Grid.Row="2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Updates -->
                                        <Border Grid.Column="0"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="20">
                                            <StackPanel>
                                                <TextBlock Text="Updates"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>

                                                <TextBlock Text="Stay current and review what changed."
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap"/>

                                                <Button Content="Check for Updates"
                                        Margin="0,18,0,0"
                                        Width="160"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Click="CheckForUpdatesButton_Click"/>

                                                <Button Content="View Changelog"
                                        Margin="0,10,0,0"
                                        Width="160"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="ViewCurrentChangelogButton_Click"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Maintenance -->
                                        <Border Grid.Column="2"
                                Background="{StaticResource CardBrush}"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="18"
                                Padding="20">
                                            <StackPanel>
                                                <TextBlock Text="Maintenance"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>

                                                <TextBlock Text="Logs, cleanup tools, and local diagnostics."
                                           Margin="0,6,0,0"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap"/>

                                                <Button Content="View Current Log"
                                        Margin="0,18,0,0"
                                        Width="150"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="OpenLogViewerButton_Click"/>

                                                <Button Content="Open Logs Folder"
                                        Margin="0,10,0,0"
                                        Width="150"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="OpenLogsFolderButton_Click"/>

                                                <Button Content="Clear Non-Pinned History"
        Margin="0,10,0,0"
        Padding="18,10"
        MinWidth="220"
        HorizontalAlignment="Left"
        Style="{StaticResource DangerButtonStyle}"
        Click="ClearHistoryButton_Click"/>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Grid>
                            </Grid>

                            <!-- Bottom info card -->
                            <Border Grid.Row="2"
                    Background="{StaticResource CardBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Database"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"/>
                                        <TextBlock Text="{Binding DatabasePath}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Current log"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   FontSize="12"/>
                                        <TextBlock Text="{Binding CurrentLogPath}"
                                   Margin="0,8,0,0"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>