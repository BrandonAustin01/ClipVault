<Window x:Class="ClipVault.UpdateAnnouncementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What's New in ClipVault"
        Width="760"
        Height="300"
        MinWidth="760"
        MinHeight="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0B1118">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#101925"/>
        <SolidColorBrush x:Key="CardBrush" Color="#121C28"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#223040"/>
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#162437"/>
        <SolidColorBrush x:Key="AccentStrongBrush" Color="#6AB2FF"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F3F7FB"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#95A7BC"/>
        <SolidColorBrush x:Key="TextSoftBrush" Color="#B9C6D5"/>

        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Background" Value="#162131"/>
            <Setter Property="BorderBrush" Value="#243548"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1C2D43"/>
                                <Setter TargetName="Border" Property="BorderBrush" Value="#35506E"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#223854"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource ActionButtonStyle}">
            <Setter Property="Background" Value="{StaticResource AccentSoftBrush}"/>
            <Setter Property="BorderBrush" Value="#315A87"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1B3047"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentStrongBrush}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#25425F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="ClipVault was updated"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock x:Name="VersionTextBlock"
                       Margin="0,6,0,0"
                       FontSize="13"
                       Foreground="{StaticResource TextMutedBrush}"/>
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Padding="16"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18">
            <TextBlock x:Name="SummaryTextBlock"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="14"
                       LineHeight="22"/>
        </Border>

        <Border x:Name="ChangelogBorder"
                Grid.Row="2"
                Margin="0,16,0,16"
                Padding="16"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1"
                CornerRadius="18"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Changelog"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                
                <TextBox x:Name="ChangelogTextBox"
                         Grid.Row="1"
                         Margin="0,14,0,0"
                         Padding="0,2,0,2"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextSoftBrush}"
                         FontSize="13"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"/>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="ToggleChangelogButton"
                    Content="View Changelog"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="ToggleChangelogButton_Click"/>

            <Button Content="Close"
                    Style="{StaticResource ActionButtonStyle}"
                    Margin="0,0,0,0"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>